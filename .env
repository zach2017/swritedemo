# ╔══════════════════════════════════════════════════════════════╗
# ║  Social Work Education Platform — Environment Variables     ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Claude API Configuration ─────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model to use (options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Simulation Mode ──────────────────────────────────────────
# Set to 'true' for demo mode with mock AI responses (no API costs)
# Set to 'false' to use live Claude API (requires valid API key)
SIMULATION_MODE=true

# ── Cloud Storage (for production deployment) ────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# GCS_BUCKET=
# AZURE_STORAGE_CONNECTION_STRING=
